    <!-- Form View -->

    <record id="todo_form_view" model="ir.ui.view">
        <field name="name">todo.task.form</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="dueDate"/>
                        </group>

                        <group>
                            <field name="assignTo"/>
                            <field name="status"/>
                            <field name="total_time"/>
                        </group>

                    </group>

                    <notebook>

                        <page string="Task Lines">

                            <field name="task_line_ids">

                                <tree editable="bottom">

                                    <field
                                            name="owner_id"
                                            widget="many2one_avatar_user"/>

                                    <field
                                            name="time"
                                            widget="float_time"
                                            sum="Total Hours"/>

                                </tree>

                            </field>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>


    <!-- Server Action -->

    <record id="todo_action_done" model="ir.actions.server">
        <field name="name">Mark As Done</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="binding_model_id" ref="model_todo_task"/>
        <field name="state">code</field>
        <field name="code">
action = records.action_mark_as_done()
        </field>
    </record>


    <!-- Menu -->

    <menuitem
            id="todo_menu_item"
            name="Tasks"
            parent="todo_management.menu_task"
            action="todo_action"
            sequence="1"/>

</odoo>