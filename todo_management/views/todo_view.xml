<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action -->

    <record id="todo_action" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">todo.task</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>


    <!-- Search View -->

    <record id="todo_search_view" model="ir.ui.view">
        <field name="name">todo.task.search</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <search>

                <field name="name"/>
                <field name="assignTo"/>

                <filter
                        name="new"
                        string="New"
                        domain="[('status','=','new')]"
                />

                <filter
                        name="in_progress"
                        string="In Progress"
                        domain="[('status','=','in_progress')]"
                />

                <filter
                        name="done"
                        string="Done"
                        domain="[('status','=','done')]"
                />

            </search>
        </field>
    </record>


    <!-- Kanban View -->

    <record id="todo_kanban_view" model="ir.ui.view">
        <field name="name">todo.task.kanban</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">

            <kanban default_group_by="status">

                <field name="name"/>
                <field name="assignTo"/>
                <field name="dueDate"/>
                <field name="status"/>
                <field name="is_late"/>

                <templates>

                    <t t-name="kanban-box">

                        <div class="oe_kanban_card">

                            <div class="oe_kanban_content">

                                <strong>
                                    <field name="name"/>
                                </strong>

                                <br/>

                                <span>
                                    <field name="assignTo"
                                           widget="many2one_avatar_user"/>
                                </span>

                                <br/>

                                <span>
                                    Due:
                                    <field name="dueDate"/>
                                </span>

                                <br/>

                                <span
                                    t-if="record.is_late.raw_value">
                                    ⚠ Late
                                </span>

                            </div>

                        </div>

                    </t>

                </templates>

            </kanban>

        </field>
    </record>


