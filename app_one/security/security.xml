<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Base Groups -->
    <record id="group_estate_user" model="res.groups">
        <field name="name">Estate User</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <record id="group_estate_admin" model="res.groups">
        <field name="name">Estate Admin</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('group_estate_user'))]"/>
    </record>

    <record id="group_estate_agent" model="res.groups">
        <field name="name">Estate Agent</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('group_estate_user'))]"/>
    </record>

    <record id="group_estate_customer" model="res.groups">
        <field name="name">Estate Customer</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('group_estate_user'))]"/>
    </record>

    <record id="group_estate_owner" model="res.groups">
        <field name="name">Estate Owner</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('group_estate_user'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="property_rule_agent" model="ir.rule">
        <field name="name">Agent: Own Properties Only</field>
        <field name="model_id" ref="model_property"/>
        <field name="domain_force">[('agent_user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_estate_agent'))]"/>
    </record>

    <record id="property_rule_owner" model="ir.rule">
        <field name="name">Owner: Own Properties Only</field>
        <field name="model_id" ref="model_property"/>
        <field name="domain_force">[('owner_user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_estate_owner'))]"/>
    </record>

    <record id="property_rule_customer" model="ir.rule">
        <field name="name">Customer: View Only</field>
        <field name="model_id" ref="model_property"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_customer'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Admin can see everything -->
    <record id="property_rule_admin" model="ir.rule">
        <field name="name">Admin: All Properties</field>
        <field name="model_id" ref="model_property"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_admin'))]"/>
    </record>
</odoo>