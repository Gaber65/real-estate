<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="estate_auth_token_view_tree" model="ir.ui.view">
        <field name="name">estate.auth.token.tree</field>
        <field name="model">estate.auth.token</field>
        <field name="arch" type="xml">
            <tree string="Authentication Tokens">
                <field name="user_id"/>
                <field name="access_token" widget="char"/>
                <field name="refresh_token" widget="char"/>
                <field name="expires_at"/>
                <field name="revoked" widget="boolean_toggle"
                       decoration-danger="revoked == True"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="estate_auth_token_view_form" model="ir.ui.view">
        <field name="name">estate.auth.token.form</field>
        <field name="model">estate.auth.token</field>
        <field name="arch" type="xml">
            <form string="Authentication Token">
                <sheet>
                    <group>
                        <group>
                            <field name="user_id" required="1"/>
                            <field name="expires_at"/>
                            <field name="revoked" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="access_token" required="1" password="True"/>
                            <field name="refresh_token" required="1" password="True"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="estate_auth_token_view_search" model="ir.ui.view">
        <field name="name">estate.auth.token.search</field>
        <field name="model">estate.auth.token</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="access_token"/>

                <filter string="Active" name="active_tokens" domain="[('revoked','=',False)]"/>
                <filter string="Revoked" name="revoked_tokens" domain="[('revoked','=',True)]"/>
                <filter string="Expired" name="expired" domain="[('expires_at','&lt;',context_today)]"/>

                <group expand="0" string="Group By">
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Status" name="group_revoked" context="{'group_by': 'revoked'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="estate_auth_token_action" model="ir.actions.act_window">
        <field name="name">Authentication Tokens</field>
        <field name="res_model">estate.auth.token</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active_tokens': 1}</field>
    </record>

    <!-- ===== REMOVE THIS MENUITEM ===== -->
</odoo>