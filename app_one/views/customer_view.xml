<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="customer_view_tree" model="ir.ui.view">
        <field name="name">estate.customer.tree</field>
        <field name="model">estate.customer</field>
        <field name="arch" type="xml">
            <tree string="Customers">
                <field name="full_name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="address"/>
                <field name="is_verified" widget="boolean_toggle"/>
                <field name="preferred_contact"/>
                <field name="date_joined"/>
                <field name="user_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="customer_view_form" model="ir.ui.view">
        <field name="name">estate.customer.form</field>
        <field name="model">estate.customer</field>
        <field name="arch" type="xml">
            <form string="Customer">
                <header>
                    <!-- REMOVED: action_send_welcome_email doesn't exist -->
                    <button name="action_view_interested_properties" type="object"
                            string="Interested Properties" class="btn-secondary"/>
                    <button name="action_view_purchased_properties" type="object"
                            string="Purchased Properties" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_user" type="object" class="oe_stat_button"
                                icon="fa-user" groups="app_one.group_estate_admin">
                            <div class="o_stat_info">
                                <span class="o_stat_text">User Account</span>
                            </div>
                        </button>
                    </div>

                    <field name="image" widget="image" class="oe_avatar"
                           options="{'size': [180, 180]}"/>

                    <div class="oe_title">
                        <h1>
                            <field name="full_name" placeholder="Customer Name..."/>
                        </h1>
                        <span class="o_form_label text-muted">
                            <field name="email" widget="email"/>
                        </span>
                    </div>

                    <group>
                        <group string="Contact Information">
                            <field name="phone" widget="phone"/>
                            <field name="address" placeholder="Street, City, Country..."/>
                            <field name="preferred_contact" widget="radio"/>
                            <field name="is_verified" widget="boolean_toggle"/>
                        </group>
                        <group string="Preferences">
                            <field name="min_price" widget="monetary"/>
                            <field name="max_price" widget="monetary"/>
                            <field name="preferred_area"/>
                            <field name="date_joined" readonly="1"/>
                        </group>
                    </group>

                    <field name="notes" placeholder="Additional notes about this customer..."/>

                    <notebook>
                        <page string="Interested Properties">
                            <field name="interested_property_ids" context="{'default_state': 'draft'}">
                                <tree string="Interested Properties">
                                    <field name="name"/>
                                    <field name="postcode"/>
                                    <field name="expected_price" sum="Total"/>
                                    <field name="state" widget="badge"/>
                                    <field name="date_availability"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Purchased Properties">
                            <field name="purchased_property_ids">
                                <tree string="Purchased Properties">
                                    <field name="name"/>
                                    <field name="postcode"/>
                                    <field name="selling_price" sum="Total"/>
                                    <field name="state" widget="badge"/>
                                    <field name="expected_selling_date"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Activity">
                            <field name="message_ids"/>
                        </page>

                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="customer_view_search" model="ir.ui.view">
        <field name="name">estate.customer.search</field>
        <field name="model">estate.customer</field>
        <field name="arch" type="xml">
            <search>
                <field name="full_name" string="Name"
                       filter_domain="['|','|','|',('full_name','ilike',self),('phone','ilike',self),('email','ilike',self),('address','ilike',self)]"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="address"/>

                <separator/>
                <filter string="Verified" name="verified" domain="[('is_verified','=',True)]"/>
                <filter string="Not Verified" name="not_verified" domain="[('is_verified','=',False)]"/>

                <separator/>
                <filter string="Has Interests" name="has_interests" domain="[('interested_property_ids','!=',False)]"/>
                <filter string="Has Purchases" name="has_purchases" domain="[('purchased_property_ids','!=',False)]"/>

                <group expand="0" string="Group By">
                    <filter string="Verification Status" name="group_verified" context="{'group_by': 'is_verified'}"/>
                    <filter string="Preferred Contact" name="group_contact"
                            context="{'group_by': 'preferred_contact'}"/>
                    <filter string="Date Joined" name="group_date" context="{'group_by': 'date_joined'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="customer_action" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">estate.customer</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_verified': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first customer
            </p>
            <p>
                Manage customers, their property interests and purchases.
            </p>
        </field>
    </record>
</odoo>